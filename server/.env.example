# VedGuide — copy to .env on the VPS (never commit .env).
# Node loads this from the server/ directory when you run `node index.js` from server/.

# --- Supabase (required for orders, tracking, admin lists) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Used for some public/config endpoints if referenced
SUPABASE_ANON_KEY=
SUPABASE_SCHEMA=v2

# --- Razorpay (required for checkout + webhook) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Dashboard → Webhooks → signing secret (required for POST /api/webhooks/razorpay)
RAZORPAY_WEBHOOK_SECRET=

# --- Product defaults ---
KUNDLI_AMOUNT_PAISE=49900
CURRENCY=INR

# --- Optional: Google Places / maps in checkout UI ---
GOOGLE_MAPS_BROWSER_KEY=

# --- Admin API + UI ---
# API: header X-Admin-Secret or Authorization: Bearer <value>
ADMIN_SECRET=
# Browser path for admin static files (default below). /admin URL is blocked for UI.
ADMIN_PANEL_PATH=/admindeoghar

# --- Server ---
PORT=3000
# production | development (affects static asset cache headers)
NODE_ENV=production

# --- Static site from same process (typical VPS: Nginx → Node, or Node only) ---
# 1 = serve this repo’s parent folder (public_html) as static + /api on one port
SERVE_STATIC=1
# If app cwd differs from file layout, set absolute path to site root (folder containing index.html)
# STATIC_ROOT=/var/www/vedguide

# Optional: relax CSP for HTML when no reverse-proxy CSP (CDN images/fonts)
# STATIC_HTML_CSP=1
